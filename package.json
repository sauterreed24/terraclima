{
  "name": "terraclima",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Terraclima — The North American Microclimate Atlas. A research-grade microclimate intelligence app for scouting relocation, travel, and hidden gems across the USA, Mexico, and Canada.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "build:pages": "cross-env VITE_BASE_PATH=/terraclima/ npm run build",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc --noEmit",
    "test:prose": "tsx scripts/test-prose.ts",
    "audit:corpus": "tsx scripts/audit-corpus.ts",
    "sanity": "tsx scripts/sanity-check.ts",
    "quality:check": "npm run typecheck && npm run test:prose && npm run audit:corpus && npm run sanity && npm run build"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "d3-geo": "^3.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
